<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ServiceScopeHQ | B2B Niche Estimates & Scopes Directory</title>
    <!-- Tailwind CSS Engine -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="styles.css">
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 font-sans min-h-screen flex flex-col transition-colors duration-200">

    <!-- Top Branded Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-40 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <div class="bg-indigo-600 text-white font-black text-xl px-3 py-1.5 rounded-lg tracking-tight">SS</div>
                <div>
                    <h1 class="text-xl font-extrabold text-slate-900 tracking-tight">ServiceScope<span class="text-indigo-600">HQ</span></h1>
                    <p class="text-xs text-slate-500 font-medium hidden sm:block">The B2B Database for Local Services, Estimates & Scopes</p>
                </div>
            </div>
            
            <div class="flex items-center space-x-4">
                <!-- Location Lock Badge -->
                <div class="flex items-center space-x-1.5 bg-slate-100 border border-slate-200 px-3 py-1.5 rounded-full text-xs font-semibold text-slate-700">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span id="currentLocationBadge">Live Estimates & Scopes</span>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Workspace Container -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col md:flex-row gap-8">
        
        <!-- Sidebar Navigation Filters -->
        <aside class="w-full md:w-64 flex-shrink-0 space-y-6">
            <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm space-y-5">
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Search Filters</h3>
                
                <!-- Strategic Vertical Tag Links -->
                <div class="space-y-1">
                    <h4 class="text-xs font-bold text-slate-500 mb-2">Market Verticals</h4>
                    <button class="w-full text-left px-3 py-2 rounded-lg text-sm font-medium transition-all bg-indigo-50 text-indigo-700" id="filter-all">
                        All Sectors
                    </button>
                    <div id="categoryContainer" class="space-y-1 mt-1">
                        <!-- Dynamic Sidebar Target Outputs -->
                    </div>
                </div>
            </div>

            <!-- MRR Modeling Engine -->
            <div class="bg-indigo-900 text-white p-5 rounded-xl shadow-md space-y-4">
                <div class="flex items-center space-x-2 border-b border-indigo-800 pb-3">
                    <h3 class="text-sm font-extrabold uppercase tracking-widest text-indigo-200">MRR Modeling Engine</h3>
                </div>
                
                <div class="space-y-3">
                    <div>
                        <label class="block text-[10px] font-bold text-indigo-300 uppercase tracking-wider mb-1">Monthly Leads</label>
                        <input type="number" id="mrrLeads" value="10" min="1" class="w-full px-3 py-1.5 bg-indigo-800 border border-indigo-700 rounded-lg text-sm text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-indigo-300 uppercase tracking-wider mb-1">Close Rate (%)</label>
                        <input type="number" id="mrrCloseRate" value="20" min="1" max="100" class="w-full px-3 py-1.5 bg-indigo-800 border border-indigo-700 rounded-lg text-sm text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-indigo-300 uppercase tracking-wider mb-1">Avg Retainer ($)</label>
                        <input type="number" id="mrrRetainer" value="1500" min="1" class="w-full px-3 py-1.5 bg-indigo-800 border border-indigo-700 rounded-lg text-sm text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all">
                    </div>
                </div>

                <div class="bg-indigo-950 p-4 rounded-lg mt-4 border border-indigo-800">
                    <div class="text-[10px] font-bold text-indigo-400 uppercase tracking-wider mb-1">Projected MRR</div>
                    <div id="mrrOutput" class="text-2xl font-black text-emerald-400 tracking-tight">$3,000<span class="text-xs text-indigo-500 font-bold ml-1">/mo</span></div>
                    
                    <div class="text-[10px] font-bold text-indigo-500 uppercase tracking-wider mt-3 mb-0.5">Annual Run Rate</div>
                    <div id="arrOutput" class="text-sm font-bold text-indigo-200">$36,000</div>
                </div>
            </div>
        </aside>

        <!-- Main Data Grid Explorer Area -->
        <section class="flex-grow flex flex-col space-y-4">
            
            <!-- Enhanced Geographic and Keyword Sorting Console -->
            <div class="bg-slate-950 p-5 rounded-xl border border-slate-800 space-y-4">
                <div class="text-xs font-bold uppercase tracking-wider text-indigo-400">Target Area Sourcing</div>
                
                <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
                    <!-- Keyword Field -->
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Scope Keyword</label>
                        <input type="text" id="dirSearch" placeholder="e.g., Tile, Shower..." 
                               class="w-full bg-slate-900 border border-slate-800 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-indigo-500 text-slate-200">
                    </div>

                    <!-- State Selector -->
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">State Region</label>
                        <select id="stateFilter" class="w-full bg-slate-900 border border-slate-800 rounded-lg px-2.5 py-2 text-xs focus:outline-none focus:border-indigo-500 text-slate-300">
                            <option value="">All States</option>
                            <option value="GA">Georgia (GA)</option>
                            <option value="FL">Florida (FL)</option>
                            <option value="TX">Texas (TX)</option>
                        </select>
                    </div>

                    <!-- City Selector (Populates dynamically based on state choice) -->
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">City Hub</label>
                        <select id="cityFilter" disabled class="w-full bg-slate-900 border border-slate-800 rounded-lg px-2.5 py-2 text-xs focus:outline-none focus:border-indigo-500 text-slate-500 disabled:opacity-50">
                            <option value="">Select State First</option>
                        </select>
                    </div>

                    <!-- ZIP Code Direct Input -->
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">ZIP Code Override</label>
                        <input type="text" id="zipFilter" placeholder="e.g., 31008" maxlength="5"
                               class="w-full bg-slate-900 border border-slate-800 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-indigo-500 text-slate-200">
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-between bg-white px-6 py-4 rounded-xl border border-slate-200 shadow-sm">
                <div class="text-sm font-medium text-slate-500">
                    Showing <span id="displayedCount" class="font-bold text-slate-800">0</span> of <span id="totalCount" class="font-bold text-slate-800">0</span> Service Scopes
                </div>
                <div class="flex space-x-2">
                    <select id="priceFilter" class="text-xs font-semibold bg-slate-50 border border-slate-200 rounded-lg px-2.5 py-1.5 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        <option value="">All Price Levels</option>
                        <option value="High Ticket">High Ticket</option>
                        <option value="Mid Ticket">Mid Ticket</option>
                        <option value="Low Ticket">Low Ticket</option>
                    </select>
                </div>
            </div>

            <!-- Directory Listing Container -->
            <div id="directoryGrid" class="grid grid-cols-1 gap-4">
                <!-- Javascript Renders Entries Instantly In This Zone -->
            </div>
        </section>
    </main>

    <!-- Unified Lead Generation Modal Framework -->
    <div id="leadModal" class="fixed inset-0 z-50 overflow-y-auto hidden bg-slate-900/50 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-xl border border-slate-200 w-full max-w-lg overflow-hidden transform transition-all">
            <div class="bg-slate-900 text-white px-6 py-4 flex items-center justify-between">
                <div>
                    <h3 id="modalNicheName" class="text-lg font-bold tracking-tight">Service Lead Dispatch</h3>
                    <p id="modalCategory" class="text-xs text-indigo-400 font-semibold uppercase tracking-wider"></p>
                </div>
                <button onclick="closeModal()" class="text-slate-400 hover:text-white transition-all text-xl font-bold">&times;</button>
            </div>
            
            <!-- Native Netlify Lead Intake Engine Wrapper -->
            <form name="servicescopehq-leads" method="POST" data-netlify="true" class="p-6 space-y-4">
                <input type="hidden" name="form-name" value="servicescopehq-leads" />
                <input type="hidden" id="formNicheId" name="target_niche_id" value="" />
                <input type="hidden" id="formNicheName" name="target_niche_name" value="" />
                
                <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-3.5 text-xs text-indigo-800 space-y-1">
                    <p class="font-bold flex items-center">
                        🎁 Resource Unlocked: <span id="modalResourceName" class="underline ml-1"></span>
                    </p>
                    <p class="opacity-90">Fill out your routing parameters below to fetch your resource file and direct quotes from verification checked contractors.</p>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1">Your Name</label>
                        <input type="text" name="client_name" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1">Phone Number</label>
                        <input type="tel" name="client_phone" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1">Email Address</label>
                    <input type="email" name="client_email" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-1">Target ZIP Code / City Location</label>
                    <input type="text" id="formLocationInput" name="client_location" value="" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                </div>

                <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-4 rounded-lg shadow-md transition-all uppercase tracking-wider text-xs">
                    Authorize Request & Download Template
                </button>
            </form>
        </div>
    </div>

    <!-- Page Footer -->
    <footer class="bg-white border-t border-slate-200 mt-12 py-6 text-center text-xs text-slate-400 font-medium">
        &copy; 2026 ServiceScopeHQ. All rights reserved. Powered by Serverless Cloud Operations.
    </footer>

    <!-- Run Logic Orchestration Hook -->
    <script src="app.js"></script>
</body>
</html>
